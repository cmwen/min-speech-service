{
  "name": "min-speech-service",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./dist/src/public-api.js"
  },
  "types": "./dist/src/public-api.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:integration": "vitest run test/integration.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.4",
    "hono": "^4.10.4",
    "openai": "^6.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^24.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
